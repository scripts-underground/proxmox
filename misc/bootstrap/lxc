# Bootstrap for LXC scripts — sourced at the END of each script
# Has access to all functions and variables defined in the calling script

if ! declare -F install_script >/dev/null 2>&1; then
  echo "Error: install_script() not defined"
  exit 1
fi

variables
color
catch_errors

start
build_container
description

declare -F post_install_script >/dev/null 2>&1 && post_install_script

msg_ok "Completed Successfully!\n"
